# =============================================================================
# CARBONTRACK - .gitignore
# Monorepo: Node.js Backend + React Frontend + React Native + Python Desktop
# =============================================================================


###############################################################################
# Environment & Secrets
###############################################################################

.env
.env.*
!.env.example

**/.env
**/.env.*

.aws/
*.pem
*.key
*.p12
*.p8
*.crt
*.csr

credentials.json
aws-credentials.json


###############################################################################
# Node.js
###############################################################################

**/node_modules/

npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

.npm/
.pnpm-store/

.eslintcache
.stylelintcache

*.tsbuildinfo


###############################################################################
# Build Output
###############################################################################

dist/
build/
out/
coverage/
.nyc_output/

**/dist/
**/build/
**/.vite/
**/dist-ssr/


###############################################################################
# Python
###############################################################################

__pycache__/
*.py[cod]
*.pyo
*.pyd

venv/
.venv/
ENV/
env/

.pytest_cache/
.mypy_cache/
.pyright/
.tox/
.coverage
coverage.xml
htmlcov/

*.egg-info/
.eggs/
wheels/

emissions.csv
codecarbon.log

.ipynb_checkpoints/


###############################################################################
# React Native / Expo
###############################################################################

.expo/
**/.expo/

expo-env.d.ts

android/
ios/

web-build/
.metro-health-check*

.kotlin/


###############################################################################
# Database
###############################################################################

*.db
*.sqlite
*.sqlite3

data/db/
dump/
mongodump/


###############################################################################
# IDEs
###############################################################################

.vscode/
.idea/

*.iml
*.ipr
*.iws

*.swp
*.swo
*.swn


###############################################################################
# Operating System
###############################################################################

.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/
.Spotlight-V100
.Trashes
._*


###############################################################################
# Logs
###############################################################################

*.log
logs/


###############################################################################
# Temporary Files
###############################################################################

*.tmp
*.temp
*.bak
*.orig
*.pid


###############################################################################
# Archives
###############################################################################

*.zip
*.tar
*.tar.gz
*.rar
*.7z


###############################################################################
# Runtime Files
###############################################################################

uploads/
python_app/outputs/


###############################################################################
# Optional
###############################################################################

# Ignore lock files only if you intentionally don't use them.
# Normally they SHOULD be committed.

# package-lock.json
# yarn.lock
# pnpm-lock.yaml