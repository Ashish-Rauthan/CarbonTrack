# =============================================================================
# CARBONTRACK — .gitignore
# Covers: Node.js backend, React frontend, Python desktop app, React Native
# =============================================================================


# =============================================================================
# SECRETS & ENVIRONMENT VARIABLES  ← most important, never commit these
# =============================================================================
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env.staging

# Specific env files across the monorepo
web_app/backend/.env
web_app/frontend/.env
python_app/.env
mobile_app/.env

# AWS credentials (never commit)
.aws/
aws-credentials.json
credentials.json


# =============================================================================
# NODE / JAVASCRIPT
# =============================================================================
node_modules/
web_app/backend/node_modules/
web_app/frontend/node_modules/
mobile_app/node_modules/

# Build output
web_app/frontend/dist/
web_app/frontend/dist-ssr/
web_app/frontend/.vite/
build/
out/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.log

# Lock files (keep package-lock.json or yarn.lock, not both)
# Uncomment the one you DON'T use:
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# Cache
.npm
.eslintcache
.stylelintcache
.parcel-cache/

# TypeScript
*.tsbuildinfo

# Vite
*.local


# =============================================================================
# PYTHON
# =============================================================================
# Virtual environments
venv/
env/
.venv/
.env/
ENV/
python_app/venv/
python_app/.venv/

# Bytecode
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/
wheels/
*.whl
MANIFEST

# PyInstaller
*.manifest
*.spec

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
coverage.xml
*.cover
*.py,cover

# CodeCarbon output files (auto-generated during tracking)
emissions.csv
python_app/emissions.csv
codecarbon.log
python_app/codecarbon.log

# Jupyter
.ipynb_checkpoints/
*.ipynb

# mypy / pyright
.mypy_cache/
.dmypy.json
dmypy.json
.pyright/


# =============================================================================
# REACT NATIVE / EXPO
# =============================================================================
# Expo
mobile_app/.expo/
mobile_app/dist/
mobile_app/web-build/
expo-env.d.ts

# Native generated folders (Expo managed — do not commit)
mobile_app/ios/
mobile_app/android/
mobile_app/.kotlin/

# Metro bundler
.metro-health-check*

# Expo example leftovers
mobile_app/app-example/


# =============================================================================
# DATABASE
# =============================================================================
# Local MongoDB data directory (if running mongo locally)
data/db/
*.db
*.sqlite
*.sqlite3

# MongoDB dump files
dump/
mongodump/


# =============================================================================
# OPERATING SYSTEM
# =============================================================================
# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Icon?

# Windows
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# Linux
*~


# =============================================================================
# EDITORS & IDEs
# =============================================================================
# VS Code (keep .vscode/extensions.json if you want, ignore the rest)
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# JetBrains (IntelliJ, PyCharm, WebStorm)
.idea/
*.iml
*.iws
*.ipr

# Vim / Neovim
*.swp
*.swo
*.swn
Session.vim
.netrwhist

# Emacs
*~
\#*\#
.\#*

# Sublime Text
*.sublime-project
*.sublime-workspace


# =============================================================================
# TESTING & COVERAGE
# =============================================================================
coverage/
.nyc_output/
test-results/
playwright-report/
.playwright/


# =============================================================================
# DOCKER (if added later)
# =============================================================================
# Uncomment if you add Docker:
# .dockerignore is separate, but these are common local artifacts
# docker-compose.override.yml


# =============================================================================
# MISCELLANEOUS
# =============================================================================
# Compressed files
*.zip
*.tar
*.tar.gz
*.rar
*.7z

# Temporary files
*.tmp
*.temp
*.bak
*.orig
*.pid

# SSL certificates (never commit private keys)
*.pem
*.key
*.p12
*.p8
*.mobileprovision
*.crt
*.csr

# Uploaded/generated files at runtime
uploads/
python_app/outputs/
